{"segments": [{"text": "Slow German, der Podcast zum Deutsch lernen.", "start": 0.251, "end": 3.637, "no_speech_prob": 0}, {"text": "Mit Annik Rubens.", "start": 3.677, "end": 6.642, "no_speech_prob": 0}, {"text": "Hallo, was machst du hier?", "start": 6.682, "end": 8.805, "no_speech_prob": 0}, {"text": "Hallo, ich tanke mein Auto.", "start": 8.825, "end": 11.59, "no_speech_prob": 0}, {"text": "Tanke?", "start": 11.63, "end": 12.552, "no_speech_prob": 0}, {"text": "Was ist das?", "start": 12.592, "end": 13.153, "no_speech_prob": 0}, {"text": "Tanken bedeutet Benzin oder Diesel in das Auto füllen.", "start": 14.124, "end": 19.228, "no_speech_prob": 0}, {"text": "Autos brauchen Treibstoff, um zu fahren.", "start": 19.268, "end": 22.77, "no_speech_prob": 0}, {"text": "Oh, verstehe.", "start": 22.87, "end": 24.712, "no_speech_prob": 0}, {"text": "Woher kommt das Benzin?", "start": 24.752, "end": 26.793, "no_speech_prob": 0}, {"text": "Das Benzin kommt aus der Zapfsäule.", "start": 26.833, "end": 30.236, "no_speech_prob": 0}, {"text": "Siehst du diese Maschine?", "start": 30.276, "end": 32.537, "no_speech_prob": 0}, {"text": "Das ist eine Zapfsäule.", "start": 32.577, "end": 34.519, "no_speech_prob": 0}, {"text": "Ja, ich sehe.", "start": 34.979, "end": 36.959, "no_speech_prob": 0}, {"text": "Und wie funktioniert sie?", "start": 37.099, "end": 39.74, "no_speech_prob": 0}, {"text": "Zuerst stecke ich den Zapfhahn in den Tank meines Autos.", "start": 39.76, "end": 46.041, "no_speech_prob": 0}, {"text": "Dann drücke ich den Hebel und das Benzin fließt in den Tank.", "start": 46.061, "end": 51.282, "no_speech_prob": 0}, {"text": "Wie viel Benzin brauchst du?", "start": 51.962, "end": 53.903, "no_speech_prob": 0}, {"text": "Ich tanke meistens voll.", "start": 53.943, "end": 56.363, "no_speech_prob": 0}, {"text": "Das bedeutet, ich fülle den Tank komplett auf.", "start": 56.383, "end": 61.204, "no_speech_prob": 0}, {"text": "Heute brauche ich 50 Liter.", "start": 61.244, "end": 64.205, "no_speech_prob": 0}, {"text": "Verstehe.", "start": 64.78, "end": 66.061, "no_speech_prob": 0}, {"text": "Und was ist dieser Ort noch?", "start": 66.161, "end": 68.602, "no_speech_prob": 0}, {"text": "Das ist eine Tankstelle.", "start": 68.642, "end": 71.063, "no_speech_prob": 0}, {"text": "Hier kann man nicht nur tanken, sondern auch das Auto waschen, Luft in die Reifen füllen und manchmal kleine Einkäufe im Shop erledigen.", "start": 71.083, "end": 83.108, "no_speech_prob": 0}, {"text": "Luft in die Reifen füllen?", "start": 83.168, "end": 86.289, "no_speech_prob": 0}, {"text": "Warum?", "start": 86.369, "end": 87.65, "no_speech_prob": 0}, {"text": "Reifen brauchen Luft, um richtig zu funktionieren.", "start": 87.79, "end": 91.772, "no_speech_prob": 0}, {"text": "Wenn sie nicht genug Luft haben, kann das Auto nicht gut fahren.", "start": 92.959, "end": 98.064, "no_speech_prob": 0}, {"text": "Oh, interessant.", "start": 98.985, "end": 101.147, "no_speech_prob": 0}, {"text": "Und was kaufst du im Shop?", "start": 101.187, "end": 103.609, "no_speech_prob": 0}, {"text": "Ich kaufe oft Snacks oder Getränke für die Fahrt.", "start": 103.65, "end": 108.114, "no_speech_prob": 0}, {"text": "Manchmal auch Motoröl oder eine Zeitung.", "start": 108.154, "end": 112.878, "no_speech_prob": 0}, {"text": "Was ist Motoröl?", "start": 112.939, "end": 113.899, "no_speech_prob": 0}, {"text": "Motoröl ist eine Flüssigkeit, die der Motor des Autos braucht, um gut zu laufen.", "start": 114.95, "end": 123.315, "no_speech_prob": 0}, {"text": "Es hilft, die Teile im Motor zu schmieren.", "start": 123.355, "end": 127.037, "no_speech_prob": 0}, {"text": "Danke für die Erklärung.", "start": 127.718, "end": 129.959, "no_speech_prob": 0}, {"text": "Die Tankstelle ist ein wichtiger Ort, oder?", "start": 129.979, "end": 133.141, "no_speech_prob": 0}, {"text": "Ja, das stimmt.", "start": 133.181, "end": 135.262, "no_speech_prob": 0}, {"text": "Ohne Tankstellen könnten wir nicht weit fahren.", "start": 135.302, "end": 139.285, "no_speech_prob": 0}, {"text": "Es ist ein wichtiger Teil unseres Lebens.", "start": 139.325, "end": 142.247, "no_speech_prob": 0}, {"text": "Aber es gibt mittlerweile immer mehr E-Autos, die fahren mit Strom.", "start": 143.219, "end": 150.169, "no_speech_prob": 0}, {"text": "Die brauchen keine Tankstellen mehr.", "start": 150.209, "end": 153.073, "no_speech_prob": 0}, {"text": "Zumindest keine, die Benzin und Diesel verkaufen.", "start": 153.093, "end": 157.199, "no_speech_prob": 0}, {"text": "Das verstehe ich jetzt.", "start": 157.88, "end": 159.982, "no_speech_prob": 0}, {"text": "Vielen Dank für deine Hilfe.", "start": 160.002, "end": 162.445, "no_speech_prob": 0}, {"text": "Gern geschehen.", "start": 162.465, "end": 163.727, "no_speech_prob": 0}, {"text": "Gute Reise auf der Erde.", "start": 163.747, "end": 165.248, "no_speech_prob": 0}], "words": [{"word": "Slow", "start": 0.251, "end": 0.512}, {"word": "German,", "start": 0.572, "end": 1.393}, {"word": "der", "start": 1.433, "end": 1.634}, {"word": "Podcast", "start": 1.674, "end": 2.295}, {"word": "zum", "start": 2.335, "end": 2.515}, {"word": "Deutsch", "start": 2.555, "end": 2.856}, {"word": "lernen.", "start": 2.896, "end": 3.637}, {"word": "Mit", "start": 3.677, "end": 3.998}, {"word": "Annik", "start": 4.078, "end": 4.398}, {"word": "Rubens.", "start": 4.478, "end": 6.642}, {"word": "Hallo,", "start": 6.682, "end": 7.303}, {"word": "was", "start": 7.343, "end": 7.483}, {"word": "machst", "start": 7.523, "end": 7.744}, {"word": "du", "start": 7.784, "end": 7.944}, {"word": "hier?", "start": 7.964, "end": 8.805}, {"word": "Hallo,", "start": 8.825, "end": 9.747}, {"word": "ich", "start": 9.787, "end": 9.927}, {"word": "tanke", "start": 9.987, "end": 10.448}, {"word": "mein", "start": 10.468, "end": 10.749}, {"word": "Auto.", "start": 10.809, "end": 11.59}, {"word": "Tanke?", "start": 11.63, "end": 12.552}, {"word": "Was", "start": 12.592, "end": 12.772}, {"word": "i