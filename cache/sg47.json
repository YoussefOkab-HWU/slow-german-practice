{"segments": [{"text": "Slow German, der Podcast zum Deutsch lernen.", "start": 0.031, "end": 4.276, "no_speech_prob": 0}, {"text": "Mit Annik Rubens.", "start": 4.296, "end": 4.837, "no_speech_prob": 0}, {"text": "Heute mal eine ganz andere Folge von Slow German, denn Alessio hat mich gebeten, die häufigsten unregelmäßigen Verben zu sprechen.", "start": 18.78, "end": 26.243, "no_speech_prob": 0}, {"text": "So könnt ihr euch das immer wieder anhören und dann vielleicht lernen, wie sie korrekt ausgesprochen werden.", "start": 26.263, "end": 37.106, "no_speech_prob": 0}, {"text": "Bringen, brachte, hat gebracht.", "start": 37.126, "end": 43.668, "no_speech_prob": 0}, {"text": "Haben, hatte, hat gehabt.", "start": 43.708, "end": 45.869, "no_speech_prob": 0}, {"text": "Kennen kannte, hat gekannt.", "start": 50.113, "end": 56.374, "no_speech_prob": 0}, {"text": "Nennen nannte, hat genannt.", "start": 56.414, "end": 62.695, "no_speech_prob": 0}, {"text": "Rennen rannte, ist gerannt.", "start": 62.775, "end": 69.136, "no_speech_prob": 0}, {"text": "Senden sandte, hat gesandt.", "start": 69.196, "end": 75.538, "no_speech_prob": 0}, {"text": "Stehen stand, hat gestanden.", "start": 75.598, "end": 77.878, "no_speech_prob": 0}, {"text": "Tun, tat, hat getan.", "start": 82.02, "end": 87.241, "no_speech_prob": 0}, {"text": "Wenden, wandte, hat gewandt.", "start": 87.281, "end": 93.363, "no_speech_prob": 0}, {"text": "Bitten, bat, hat gebeten.", "start": 93.403, "end": 99.825, "no_speech_prob": 0}, {"text": "Essen, aß, hat gegessen.", "start": 99.905, "end": 106.306, "no_speech_prob": 0}, {"text": "Fressen, fraß, hat gefressen.", "start": 106.366, "end": 108.847, "no_speech_prob": 0}, {"text": "Geben gab hat gegeben.", "start": 113.037, "end": 119.239, "no_speech_prob": 0}, {"text": "Geschehen geschah ist geschehen.", "start": 119.279, "end": 125.722, "no_speech_prob": 0}, {"text": "Lesen las hat gelesen.", "start": 125.762, "end": 132.484, "no_speech_prob": 0}, {"text": "Liegen lag hat gelegen.", "start": 132.524, "end": 138.926, "no_speech_prob": 0}, {"text": "Messen maß hat gemessen.", "start": 138.966, "end": 141.267, "no_speech_prob": 0}, {"text": "Sehen, sah, hat gesehen Sein, war, ist gewesen Sitzen, saß, ist gesessen Treten, trat, hat getreten Vergessen, vergaß, hat vergessen", "start": 145.421, "end": 174.142, "no_speech_prob": 0}, {"text": "Befehlen, Befall, hat befohlen.", "start": 178.63, "end": 185.255, "no_speech_prob": 0}, {"text": "Beginnen, begann, hat begonnen.", "start": 185.295, "end": 191.28, "no_speech_prob": 0}, {"text": "Brechen, brach, hat gebrochen.", "start": 191.34, "end": 198.105, "no_speech_prob": 0}, {"text": "Empfehlen, Empfahl, hat empfohlen.", "start": 198.145, "end": 205.17, "no_speech_prob": 0}, {"text": "Erschrecken, erschrak, ist erschrocken.", "start": 205.21, "end": 207.912, "no_speech_prob": 0}, {"text": "gelten, galt, hat gegolten gewinnen, gewann, hat gewonnen helfen, half, hat geholfen kommen, kam, ist gekommen nehmen, nahm, hat genommen", "start": 212.164, "end": 240.246, "no_speech_prob": 0}, {"text": "Schwimmen, Schwamm, ist geschwommen.", "start": 244.477, "end": 251.061, "no_speech_prob": 0}, {"text": "Sprechen, Sprach, hat gesprochen.", "start": 251.101, "end": 257.745, "no_speech_prob": 0}, {"text": "Stechen, Stach, hat gestochen.", "start": 257.785, "end": 264.369, "no_speech_prob": 0}, {"text": "Stehlen, Stahl, hat gestohlen.", "start": 264.409, "end": 271.193, "no_speech_prob": 0}, {"text": "Sterben, starb, ist gestorben.", "start": 271.233, "end": 273.795, "no_speech_prob": 0}, {"text": "treffen, traf, hat getroffen, verderben, verdarb, ist verdorben, werben, warb, hat geworben, werfen, warf, hat geworfen, binden, band, hat gebunden,", "start": 278.158, "end": 305.319, "no_speech_prob": 0}, {"text": "Eindringen, drang ein, ist eingedrungen.", "start": 308.99, "end": 315.251, "no_speech_prob": 0}, {"text": "Empfinden, empfand, hat empfunden.", "start": 315.291, "end": 322.293, "no_speech_prob": 0}, {"text": "Finden, fand, hat gefunden.", "start": 322.353, "end": 328.994, "no_speech_prob": 0}, {"text": "Gelingen, gelang, ist gelungen.", "start": 329.034, "end": 335.375, "no_speech_prob": 0}, {"text": "Klingen, klang, hat geklungen.", "start": 335.415, "end": 337.796, "no_speech_prob": 0}, {"text": "Singen, sang hat gesungen.", "start": 342.003, "end": 348.106, "no_speech_prob": 0}, {"text": "Sinken, sank ist gesunken.", "start": 348.166, "end": 354.669, "no_speech_prob": 0}, {"text": "Springen, sprang ist gesprungen.", "start": 354.709, "end": 360.912, "no_speech_prob": 0}, {"text": "Stinken, stank hat gestunken.", "start": 360.952, "end": 367.356, "no_speech_prob": 0}, {"text": "Trinken, trank hat getrunken.", "start": 367.416, "end": 369.977, "no_speech_prob": 0}, {"text": "Verschwinden, verschwand, ist verschwunden.", "start": 374.052, "end": 380.733, "no_speech_prob": 0}, {"text": "Zwingen, zwang, hat gezwungen.", "start": 380.793, "end": 387.134, "no_speech_prob": 0}, {"text": "Blasen, blies, hat geblasen.", "start": 387.194, "end": 393.735, "no_speech_prob": 0}, {"text": "Braten, briet, hat gebraten.", "start": 393.775, "end": 400.657, "no_speech_prob": 0}, {"text": "Empfangen, empfing, hat empfangen.", "start": 400.697, "end": 403.217, "no_speech_prob": 0}, {"text": "Fallen, fiel, ist gefallen.", "start": 407.4, "end": 413.584, "no_speech_prob": 0}, {"text": "Fangen, fing, hat gefangen.", "start": 413.624, "end": 420.028, "no_speech_prob": 0}, {"text": "Gehen, ging, ist gegangen.", "start": 420.068, "end": 425.872, "no_speech_prob": 0}, {"text": "Geraten, geriet, ist geraten.", "start": 425.912, "end": 432.416, "no_speech_prob": 0}, {"text": "Halten, hielt, hat gehalten.", "start": 432.476, "end": 434.838, "no_speech_prob": 0}, {"text": "Hangen, hing, hat gehangen.", "start": 438.892, "end": 445.234, "no_speech_prob": 0}, {"text": "Lassen, lies, hat gelassen.", "start": 445.294, "end": 451.536, "no_speech_prob": 0}, {"text": "Laufen, lief, ist gelaufen.", "start": 451.596, "end": 457.979, "no_speech_prob": 0}, {"text": "Raten, riet, hat geraten.", "start": 458.059, "end": 464.581, "no_speech_prob": 0}, {"text": "Schlafen, schlief, hat geschlafen.", "start": 464.641, "end": 467.282, "no_speech_prob": 0}, {"text": "Heißen, hieß, hat geheißen.", "start": 471.06, "end": 477.145, "no_speech_prob": 0}, {"text": "Beißen, biss, hat gebissen.", "start": 477.205, "end": 483.751, "no_speech_prob": 0}, {"text": "Bleiben, blieb, ist geblieben.", "start": 483.791, "end": 490.437, "no_speech_prob": 0}, {"text": "Gleichen, glich, hat geglichen.", "start": 490.477, "end": 496.281, "no_speech_prob": 0}, {"text": "Gleiten, glitt, ist geglitten.", "start": 496.342, "end": 499.064, "no_speech_prob": 0}, {"text": "Greifen, Griff, hat gegriffen.", "start": 503.312, "end": 510.014, "no_speech_prob": 0}, {"text": "Leiden, litt, hat gelitten.", "start": 510.074, "end": 516.655, "no_speech_prob": 0}, {"text": "Leien, lie, hat geliehen.", "start": 516.715, "end": 522.797, "no_speech_prob": 0}, {"text": "Meiden, mied, hat gemieden.", "start": 522.837, "end": 528.978, "no_speech_prob": 0}, {"text": "Pfeifen, pfiff, hat gepfiffen.", "start": 528.998, "end": 531.659, "no_speech_prob": 0}, {"text": "Reiben, Rieb, hat gerieben.", "start": 536.0, "end": 541.882, "no_speech_prob": 0}, {"text": "Reißen, Riss, hat gerissen.", "start": 541.962, "end": 548.103, "no_speech_prob": 0}, {"text": "Scheinen, Schien, hat geschienen.", "start": 548.143, "end": 554.985, "no_speech_prob": 0}, {"text": "Schleichen, Schlich, ist geschlichen.", "start": 555.045, "end": 561.687, "no_speech_prob": 0}, {"text": "Schmeißen, Schmiss, hat geschmissen.", "start": 561.727, "end": 564.428, "no_speech_prob": 0}, {"text": "Schneiden, Schnitt, hat geschnitten.", "start": 568.685, "end": 575.489, "no_speech_prob": 0}, {"text": "Schreiben, schrieb, hat geschrieben.", "start": 575.529, "end": 582.153, "no_speech_prob": 0}, {"text": "Schreien, schrie, hat geschrien.", "start": 582.193, "end": 588.717, "no_speech_prob": 0}, {"text": "Schweigen, schwieg, hat geschwiegen.", "start": 588.757, "end": 591.599, "no_speech_prob": 0}, {"text": "Steigen, Stieg, ist gestiegen.", "start": 595.803, "end": 602.205, "no_speech_prob": 0}, {"text": "Streichen, Strich, hat gestrichen.", "start": 602.245, "end": 609.007, "no_speech_prob": 0}, {"text": "Streiten, Stritt, hat gestritten.", "start": 609.027, "end": 615.569, "no_speech_prob": 0}, {"text": "Treiben, Trieb, hat getrieben.", "start": 615.649, "end": 621.791, "no_speech_prob": 0}, {"text": "Verzeihen, Verzieh, hat verziehen.", "start": 621.831, "end": 624.752, "no_speech_prob": 0}, {"text": "Weichen, wich ist gewichen.", "start": 628.55, "end": 634.354, "no_speech_prob": 0}, {"text": "Weisen, wies hat gewiesen.", "start": 634.414, "end": 640.497, "no_speech_prob": 0}, {"text": "Stoßen, stieß hat gestoßen.", "start": 640.557, "end": 647.322, "no_speech_prob": 0}, {"text": "Rufen, rief hat gerufen.", "start": 647.422, "end": 653.485, "no_speech_prob": 0}, {"text": "Betrügen, betrog hat betrogen.", "start": 653.505, "end": 656.227, "no_speech_prob": 0}, {"text": "bewegen, bewog, hat bewogen biegen, bog, hat gebogen bieten, bot, hat geboten erloschen, erlosch, ist erloschen erwägen, erwog, hat erwogen", "start": 660.412, "end": 687.619, "no_speech_prob": 0}, {"text": "flog ist geflogen fliehen floh ist geflohen fließen floss ist geflossen frieren froh hat gefroren genießen genoss hat genossen", "start": 692.23, "end": 719.61, "no_speech_prob": 0}, {"text": "Gießen, goss, hat gegossen.", "start": 724.023, "end": 730.467, "no_speech_prob": 0}, {"text": "Heben, hob, hat gehoben.", "start": 730.507, "end": 736.491, "no_speech_prob": 0}, {"text": "Können, konnte, hat gekonnt.", "start": 736.531, "end": 742.915, "no_speech_prob": 0}, {"text": "Kriechen, kroch, ist gekrochen.", "start": 742.955, "end": 748.719, "no_speech_prob": 0}, {"text": "Lügen, log, hat gelogen.", "start": 748.799, "end": 751.181, "no_speech_prob": 0}, {"text": "Mögen, mochte, hat gemocht.", "start": 755.01, "end": 761.375, "no_speech_prob": 0}, {"text": "Riechen, roch, hat gerochen.", "start": 761.455, "end": 767.42, "no_speech_prob": 0}, {"text": "Schieben, schob, hat geschoben.", "start": 767.46, "end": 773.464, "no_speech_prob": 0}, {"text": "Schießen, schoss, hat geschossen.", "start": 773.504, "end": 779.809, "no_speech_prob": 0}, {"text": "Schließen, schloss, hat geschlossen.", "start": 779.869, "end": 782.311, "no_speech_prob": 0}, {"text": "Schmelzen, schmolz ist geschmolzen.", "start": 786.443, "end": 792.807, "no_speech_prob": 0}, {"text": "Schwellen, schwoll ist geschwollen.", "start": 792.847, "end": 799.352, "no_speech_prob": 0}, {"text": "Schwören, schwor hat geschworen.", "start": 799.392, "end": 805.496, "no_speech_prob": 0}, {"text": "Verlieren, verlor hat verloren.", "start": 805.536, "end": 812.02, "no_speech_prob": 0}, {"text": "Wiegen, wog hat gewogen.", "start": 812.08, "end": 814.242, "no_speech_prob": 0}, {"text": "ziehen, zog, hat gezogen backen, bug, hat gebacken fahren, fuhr, ist gefahren graben, grub, hat gegraben laden, lud, hat geladen", "start": 818.323, "end": 845.057, "no_speech_prob": 0}, {"text": "schaffen, schuf, hat geschaffen schlagen, schlug, hat geschlagen tragen, trug, hat getragen wachsen, wuchs, ist gewachsen waschen, wusch, hat gewaschen", "start": 849.125, "end": 876.429, "no_speech_prob": 0}, {"text": "werden, wurden, ist geworden dürfen, durfte, hat gedurft müssen, musste, hat gemusst wissen, wusste, hat gewusst", "start": 880.227, "end": 902.289, "no_speech_prob": 0}, {"text": "Slow German ist ein privater Podcast.", "start": 916.807, "end": 919.529, "no_speech_prob": 0}, {"text": "Ihr könnt die Texte zu jeder Folge auf der Internetseite slowgerman.com nachlesen.", "start": 919.569, "end": 925.733, "no_speech_prob": 0}, {"text": "Der Text erscheint auch auf eurem iPod.", "start": 925.753, "end": 929.055, "no_speech_prob": 0}, {"text": "Ich freue mich, wenn ihr mir im Internet einen kurzen Kommentar hinterlasst.", "start": 929.095, "end": 934.419, "no_speech_prob": 0}, {"text": "Oder schreibt mir eine E-Mail an podcast at slowgerman.com.", "start": 934.459, "end": 938.922, "no_speech_prob": 0}, {"text": "Schlaflos in München.", "start": 939.462, "end": 940.263, "no_speech_prob": 0}, {"text": "Wenn ihr mehr deutsche und internationale Podcasts sucht, ich empfehle einige auf 99podcasts.de.", "start": 962.399, "end": 969.705, "no_speech_prob": 0}, {"text": "Deutsche Musik, Filme und Bücher findet ihr auf slowgerman.com.", "start": 969.725, "end": 973.228, "no_speech_prob": 0}, {"text": "Bis zum nächsten Mal.", "start": 973.268, "end": 974.089, "no_speech_prob": 0}], "words": [{"word": "Slow", "start": 0.031, "end": 0.512}, {"word": "German,", "start": 0.552, "end": 1.733}, {"word": "der", "start": 1.773, "end": 2.374}, {"word": "Podcast", "start": 2.394, "end": 2.754}, {"word": "zum", "start": 2.774, "end": 3.756}, {"word": "Deutsch", "start": 3.776, "end": 4.016}, {"word": "lernen.", "start": 4.056, "end": 4.276}, {"word": "Mit", "start": 4.296, "end": 4.396}, {"word": "Annik", "start": 4.436, "end": 4.637}, {"word": "Rubens.", "start": 4.657, "end": 4.837}, {"word": "Heute", "start": 18.78, "end": 18.92}, {"word": "mal", "start": 19.0, "end": 19.14}, {"word": "eine", "start": 19.16, "end": 19.32}, {"word": "ganz", "start": 19.36, "end": 19.56}, {"word": "andere", "start": 19.58, "end": 19.84}, {"word": "Folge", "start": 19.88, "end": 20.161}, {"word": "von", "start": 20.181, "end": 20.321}, {"word": "Slow", "start": 20.361, "end": 20.581}, {"word": "German,", "start": 20.641, "end": 21.001}, {"word": "denn", "start": 21.021, "end": 21.261}, {"word": "Alessio", "start": 21.281, "end": 21.801}, {"word": "hat", "start": 21.821, "end": 21.981}, {"word": "mich", "start": 22.021, "end": 22.181}, {"word": "gebeten,", "start": 22.201, "end": 22.741}, {"word": "die", "start": 22.761, "end": 22.981}, {"word": "häufi