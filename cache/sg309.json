.133, "end": 57.913}, {"word": "wie", "start": 57.954, "end": 58.254}, {"word": "die", "start": 58.274, "end": 58.494}, {"word": "Römer", "start": 58.554, "end": 59.415}, {"word": "Deutschland", "start": 59.455, "end": 60.316}, {"word": "geprägt", "start": 60.356, "end": 60.956}, {"word": "haben.", "start": 60.996, "end": 62.197}, {"word": "Denn", "start": 62.237, "end": 62.558}, {"word": "vor", "start": 62.598, "end": 62.898}, {"word": "fast", "start": 62.938, "end": 63.599}, {"word": "2000", "start": 63.699, "end": 64.539}, {"word": "Jahren", "start": 64.6, "end": 65.62}, {"word": "war", "start": 65.66, "end": 66.021}, {"word": "ein", "start": 66.061, "end": 66.361}, {"word": "großer", "start": 66.401, "end": 67.002}, {"word": "Teil", "start": 67.082, "end": 67.883}, {"word": "des", "start": 67.923, "end": 68.203}, {"word": "heutigen", "start": 68.263, "end": 68.863}, {"word": "Deutschlands", "start": 68.903, "end": 70.044}, {"word": "Teil", "start": 70.085, "end": 70.685}, {"word": "des", "start": 70.725, "end": 70.925}, {"word": "Römischen", "start": 71.005, "end": 71.586}, {"word": "Reiches", "start": 71.666, "end": 72.927}, {"word": "oder", "start": 72.987, "end": 73.588}, {"word": "stand", "start": 73.628, "end": 74.188}, {"word": "zumindest", "start": 74.228, "end": 75.229}, {"word": "unter", "start": 75.289, "end": 75.75}, {"word": "seinem", "start": 75.79, "end": 76.35}, {"word": "Einfluss.", "start": 76.41, "end": 76.871}, {"word": "Das", "start": 78.322, "end": 78.522}, {"word": "Römische", "start": 78.622, "end": 79.243}, {"word": "Reich", "start": 79.343, "end": 80.104}, {"word": "dehnte", "start": 80.144, "end": 80.644}, {"word": "sich", "start": 80.684, "end": 81.145}, {"word": "im", "start": 81.185, "end": 81.505}, {"word": "ersten", "start": 81.565, "end": 82.025}, {"word": "Jahrhundert", "start": 82.066, "end": 82.846}, {"word": "vor", "start": 82.886, "end": 83.106}, {"word": "Christus", "start": 83.167, "end": 84.288}, {"word": "immer", "start":